NODE_ENV=development
APP_VERSION=1.0.0
GIT_SHA=local
PORT=5000
API_BASE_URL=http://localhost:5000
WEB_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/url_shortner?schema=public
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
CREATE_LINK_LIMIT_MAX=20
REDIRECT_CACHE_SECONDS=300
IP_HASH_SALT=change-this-random-secret-in-production
SHUTDOWN_TIMEOUT_MS=10000
